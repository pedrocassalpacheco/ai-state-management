# AI State Management Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# DUAL DATABASE ARCHITECTURE
# =============================================================================
# This project uses two databases optimized for different workloads:
#
# 1. Aurora RDS MySQL - ai_memory (non-partitioned, OLAP/Analytics)
#    - Normalized schema for analytical queries
#    - Best for: reports, dashboards, cross-user analytics
#
# 2. TiDB - ai_memory_colocated (partitioned, OLTP/Transactional)
#    - Denormalized schema with KEY partitioning
#    - Best for: real-time chat, user queries, production API
# =============================================================================

# -----------------------------------------------------------------------------
# Aurora RDS MySQL Configuration (ai_memory - Analytics/OLAP)
# -----------------------------------------------------------------------------
# Used for the non-partitioned database with normalized schema
AURORA_HOST=your-aurora-endpoint.rds.amazonaws.com
AURORA_PORT=3306
AURORA_USER=admin
AURORA_PASSWORD=your-secure-password

# -----------------------------------------------------------------------------
# TiDB Configuration (ai_memory_colocated - Transactional/OLTP)
# -----------------------------------------------------------------------------
# Used for the partitioned database with denormalized schema
TIDB_HOST=127.0.0.1
TIDB_PORT=3306
TIDB_USER=root
TIDB_PASSWORD=

# -----------------------------------------------------------------------------
# Legacy Database Configuration (for backward compatibility)
# -----------------------------------------------------------------------------
# These are used by older scripts and notebooks  
# When AURORA_HOST is set, they will be overridden by the application code
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=ai_memory

# -----------------------------------------------------------------------------
# Ollama Configuration
# -----------------------------------------------------------------------------
OLLAMA_HOST=http://localhost:11434
CHAT_MODEL=deepseek-r1:1.5b
EMBEDDING_MODEL=nomic-embed-text

# -----------------------------------------------------------------------------
# Application Configuration
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
ENVIRONMENT=development

# -----------------------------------------------------------------------------
# Setup Instructions
# -----------------------------------------------------------------------------
# 1. Copy this file: cp .env.example .env
# 2. Fill in your Aurora RDS credentials
# 3. Start TiDB cluster: make up
# 4. Initialize Aurora database: make init-db-aurora
# 5. Initialize TiDB database: make init-db-colocated
# 6. Load test data: make seed-dbs
