# AI State Management Environment Configuration
# Copy this file to .env and fill in your values


# -----------------------------------------------------------------------------
# Aurora RDS MySQL Configuration (Source Database)
# -----------------------------------------------------------------------------
# Aurora MySQL 8.0.x required (8.4+ incompatible with TiDB Data Migration)
# Enable binary logging for CDC: binlog_format=ROW, binlog_row_image=FULL
AURORA_HOST=
AURORA_PORT=3306
AURORA_USER=
AURORA_PASSWORD=
AURORA_DATABASE=ai_state_management
AURORA_SCHEMA=scripts/init_schema_aurora.sql

# -----------------------------------------------------------------------------
# TiDB Configuration (Replica Database - Partitioned)
# -----------------------------------------------------------------------------
# Local TiDB cluster receives data from Aurora via CDC
TIDB_HOST=127.0.0.1
TIDB_PORT=3306
TIDB_USER=root
TIDB_DATABASE=ai_state_management
TIDB_PASSWORD=
TIDB_SCHEMA=scripts/init_schema_tidb.sql

# -----------------------------------------------------------------------------
# Embedding Configuration
# -----------------------------------------------------------------------------
OLLAMA_HOST=http://localhost:11434
CHAT_MODEL=deepseek-r1:1.5b
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMENSION=768

# -----------------------------------------------------------------------------
# Data Generation Configuration
# -----------------------------------------------------------------------------
NUM_USERS=100
NUM_BOTS=15
MIN_SESSIONS_PER_USER=2
MAX_SESSIONS_PER_USER=8
MIN_MESSAGES_PER_SESSION=10
MAX_MESSAGES_PER_SESSION=50
SNAPSHOT_EVERY_N_MESSAGES=7
TARGET_SNAPSHOTS=1000
BATCH_SIZE=100
CHAT_MODEL=deepseek-r1:1.5b
EMBEDDING_MODEL=nomic-embed-text

# -----------------------------------------------------------------------------
# Application Configuration
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
ENVIRONMENT=development
